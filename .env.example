# Logo.dev publishable key
# Get your free publishable token at https://logo.dev
# This is used to fetch company logos in the application
NEXT_PUBLIC_LOGO_DEV_KEY=pk_your_logo_dev_token_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only service-role secret. Used to record user_exports and upload
# archived exports to Supabase Storage. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Neon Database (serverless Postgres)
# Runtime pooled connection string used by Prisma Client through the Neon adapter.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Optional direct connection string used by Prisma CLI commands. Falls back to
# DATABASE_URL when unset.
DIRECT_URL=postgresql://user:password@direct-host/dbname?sslmode=require
# Optional: dashboard API SWR cache TTL in milliseconds (default 3600000, 1 hour)
DASHBOARD_CACHE_TTL_MS=
# Optional: max data exports per user per rolling hour (default 20)
EXPORT_RATE_LIMIT_PER_HOUR=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional: enable analytics during local development
NEXT_PUBLIC_ENABLE_ANALYTICS=false
# Optional: enable PostHog session recording and dead-click capture
NEXT_PUBLIC_POSTHOG_ENABLE_RECORDING=false
# Optional: enable PostHog debug logging
NEXT_PUBLIC_POSTHOG_DEBUG=false

# Notifications UI Feature Flag
# Set to "disabled" to hide the notifications bell and all recently-updated dots.
NEXT_PUBLIC_NOTIFICATIONS_ENABLED=enabled

# Maintenance Mode
# Set to "true" to show a maintenance page instead of the dashboard.
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Environment Tag
# Set to DEV or PROD to show a header tag. Leave empty to hide it.
NEXT_PUBLIC_ENVIRONMENT_LABEL=DEV

# Benchmark script
# Optional dashboard server URL used by `npm run benchmark`
API_URL=http://localhost:3000
